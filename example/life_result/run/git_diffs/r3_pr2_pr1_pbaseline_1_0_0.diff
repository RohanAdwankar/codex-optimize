+def _seed_cells(width: int, height: int, seed: int) -> bytearray:
+    state = seed & 0x7FFFFFFF
+    cells = bytearray(width * height)
+    index = 0
+    for _ in range(height):
+        for _ in range(width):
+            state = (1103515245 * state + 12345) & 0x7FFFFFFF
+            cells[index] = 1 if state % 5 < 2 else 0
+            index += 1
+    return cells
+
+
+def _step_cells(
+    cells: bytearray,
+    next_cells: bytearray,
+    width: int,
+    height: int,
+) -> bytearray:
+    if height == 1:
+        if width == 1:
+            neighbors = cells[0] * 8
+            cell = cells[0]
+            next_cells[0] = 1 if neighbors == 3 or (cell and neighbors == 2) else 0
+            return next_cells
+
+        col_left = cells[-1] * 3
+        first_col = cells[0] * 3
+        col_mid = cells[1] * 3
+        neighbors = col_left + first_col + col_mid - cells[0]
+        cell = cells[0]
+        next_cells[0] = 1 if neighbors == 3 or (cell and neighbors == 2) else 0
+        for x in range(1, width - 1):
+            col_left = first_col
+            first_col = col_mid
+            col_mid = cells[x + 1] * 3
+            neighbors = col_left + first_col + col_mid - cells[x]
+            cell = cells[x]
+            next_cells[x] = 1 if neighbors == 3 or (cell and neighbors == 2) else 0
+        neighbors = first_col + col_mid + cells[0] * 3 - cells[width - 1]
+        cell = cells[width - 1]
+        next_cells[width - 1] = 1 if neighbors == 3 or (cell and neighbors == 2) else 0
+        return next_cells
+
+    first_base = 0
+    for y in range(height):
+        prev_base = (y - 1) * width
+        base = y * width
+        next_base = first_base if y + 1 == height else base + width
+        if width == 1:
+            neighbors = (cells[prev_base] + cells[base] + cells[next_base]) * 3 - cells[base]
+            cell = cells[base]
+            next_cells[base] = 1 if neighbors == 3 or (cell and neighbors == 2) else 0
+            continue
+
+        col_left = cells[prev_base + width - 1] + cells[base + width - 1] + cells[next_base + width - 1]
+        first_col = cells[prev_base] + cells[base] + cells[next_base]
+        col_mid = cells[prev_base + 1] + cells[base + 1] + cells[next_base + 1]
+        neighbors = col_left + first_col + col_mid - cells[base]
+        cell = cells[base]
+        next_cells[base] = 1 if neighbors == 3 or (cell and neighbors == 2) else 0
+        for x in range(1, width - 1):
+            col_left = first_col
+            first_col = col_mid
+            col_mid = cells[prev_base + x + 1] + cells[base + x + 1] + cells[next_base + x + 1]
+            neighbors = col_left + first_col + col_mid - cells[base + x]
+            cell = cells[base + x]
+            next_cells[base + x] = 1 if neighbors == 3 or (cell and neighbors == 2) else 0
+        last = base + width - 1
+        neighbors = first_col + col_mid + cells[prev_base] + cells[base] + cells[next_base] - cells[last]
+        cell = cells[last]
+        next_cells[last] = 1 if neighbors == 3 or (cell and neighbors == 2) else 0
+    return next_cells
+
+
+def _checksum_cells(cells: bytearray) -> int:
+    total = 0
+    for value in cells:
+        total = (total * 131 + value) % 1_000_000_007
+    return total
+
