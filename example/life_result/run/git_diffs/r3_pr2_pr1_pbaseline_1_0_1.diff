+            next_cells[0] = 1 if neighbors == 3 or (cell and neighbors == 2) else 0
+            return next_cells, cells
+
+        last_index = width - 1
+        col_left = cells[last_index] * 3
+        first_col = cells[0] * 3
+        col_mid = cells[1] * 3
+        cell = cells[0]
+        neighbors = col_left + first_col + col_mid - cell
+        next_cells[0] = 1 if neighbors == 3 or (cell and neighbors == 2) else 0
+        for x in range(1, last_index):
+            col_left = first_col
+            first_col = col_mid
+            col_mid = cells[x + 1] * 3
+            cell = cells[x]
+            neighbors = col_left + first_col + col_mid - cell
+            next_cells[x] = 1 if neighbors == 3 or (cell and neighbors == 2) else 0
+        cell = cells[last_index]
+        neighbors = first_col + col_mid + (cells[0] * 3) - cell
+        next_cells[last_index] = 1 if neighbors == 3 or (cell and neighbors == 2) else 0
+        return next_cells, cells
+
+    first_base = row_starts[0]
+    last_col = width - 1
+    for y, base in enumerate(row_starts):
+        prev_base = row_starts[y - 1]
+        next_base = first_base if y + 1 == height else row_starts[y + 1]
+        if width == 1:
+            cell = cells[base]
+            neighbors = (cells[prev_base] + cell + cells[next_base]) * 3 - cell
+            next_cells[base] = 1 if neighbors == 3 or (cell and neighbors == 2) else 0
+            continue
+
+        prev_last = prev_base + last_col
+        next_last = next_base + last_col
+        col_left = cells[prev_last] + cells[base + last_col] + cells[next_last]
+        first_col = cells[prev_base] + cells[base] + cells[next_base]
+        col_mid = cells[prev_base + 1] + cells[base + 1] + cells[next_base + 1]
+
+        cell = cells[base]
+        neighbors = col_left + first_col + col_mid - cell
+        next_cells[base] = 1 if neighbors == 3 or (cell and neighbors == 2) else 0
+
+        for x in range(1, last_col):
+            idx = base + x
+            col_left = first_col
+            first_col = col_mid
+            col_mid = cells[prev_base + x + 1] + cells[idx + 1] + cells[next_base + x + 1]
+            cell = cells[idx]
+            neighbors = col_left + first_col + col_mid - cell
+            next_cells[idx] = 1 if neighbors == 3 or (cell and neighbors == 2) else 0
+
+        last_idx = base + last_col
+        cell = cells[last_idx]
+        neighbors = first_col + col_mid + (cells[prev_base] + cells[base] + cells[next_base]) - cell
+        next_cells[last_idx] = 1 if neighbors == 3 or (cell and neighbors == 2) else 0
+    return next_cells, cells
+
+
+def _checksum_cells(cells: bytearray) -> int:
+    total = 0
+    for value in cells:
+        total = (total * 131 + value) % 1_000_000_007
+    return total
