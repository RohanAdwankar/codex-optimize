+def _seed_cells(size: int, seed: int) -> bytearray:
+    state = seed & 0x7FFFFFFF
+    cells = bytearray(size)
+    for index in range(size):
+        state = (1103515245 * state + 12345) & 0x7FFFFFFF
+        cells[index] = 1 if state % 5 < 2 else 0
+    return cells
+
